# Copy this file to `.env.pass.template` and replace each URI with the
# corresponding Proton Pass secret reference.
#
# Proton Pass CLI secret-reference format:
#   {{ pass://SHARE_ID/ITEM_ID/FIELD }}
#
# You can discover values with:
#   pass-cli share list
#   pass-cli item list --vault-name "<vault>" --output json
#   pass-cli item view --vault-name "<vault>" --item-title "<title>" --output json

VITE_SUPABASE_URL={{ pass://SHARE_ID/SUPABASE_ITEM_ID/url }}
VITE_SUPABASE_ANON_KEY={{ pass://SHARE_ID/SUPABASE_ITEM_ID/anon_key }}
DATABASE_URL={{ pass://SHARE_ID/SUPABASE_ITEM_ID/database_url }}
ATLAS_DATABASE_URL={{ pass://SHARE_ID/SUPABASE_ITEM_ID/atlas_database_url }}

# AI provider keys used by local scripts/services.
GEMINI_API_KEY={{ pass://SHARE_ID/GEMINI_ITEM_ID/password }}
VITE_ANTHROPIC_API_KEY={{ pass://SHARE_ID/ANTHROPIC_ITEM_ID/password }}
VITE_OPENAI_API_KEY={{ pass://SHARE_ID/OPENAI_ITEM_ID/password }}