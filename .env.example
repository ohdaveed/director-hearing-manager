VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Atlas Database Schema Management
# Set these in your local .env (never commit secrets):
# ATLAS_DATABASE_URL=postgres://postgres:password@db.xxxxx.supabase.co:5432/postgres?sslmode=require
# ATLAS_DEV_URL=docker://postgres/17/dev?search_path=public
# DATABASE_URL is used by the db:inspect script (standalone atlas schema inspect command):
# DATABASE_URL=$ATLAS_DATABASE_URL

