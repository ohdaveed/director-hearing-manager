{
  "$schema": "https://opencode.ai/config.json",
  "model": "nemotron-3-super-free",
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "enabled": true,
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"]
    },
    "filesystem": {
      "type": "local",
      "enabled": true,
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/parallax/director-hearing-manager"
      ]
    },
    "git": {
      "type": "local",
      "enabled": true,
      "command": "uvx",
      "args": ["mcp-server-git"]
    },
    "fetch": {
      "type": "local",
      "enabled": true,
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-fetch"]
    },
    "Supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp",
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "enabled": true,
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-playwright"]
    },
    "postgresql": {
      "type": "local",
      "enabled": true,
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://postgres:postgres@localhost:5432/postgres"
      ]
    }
  }
}
